{
  "name": "iobroker.dashboard-ng",
  "version": "0.2.2",
  "description": "Modern responsive dashboard adapter for ioBroker.",
  "keywords": [
    "ioBroker",
    "dashboard",
    "visualization",
    "smart-home",
    "adapter"
  ],
  "homepage": "https://github.com/dude2k/ioBroker.dashboard-ng#readme",
  "bugs": {
    "url": "https://github.com/dude2k/ioBroker.dashboard-ng/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dude2k/ioBroker.dashboard-ng.git"
  },
  "license": "MIT",
  "author": "ioBroker Dashboard-NG contributors",
  "main": "build/src/main.js",
  "types": "build/src/main.d.ts",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "admin",
    "build",
    "docs",
    "io-package.json",
    "LICENSE",
    "README.md",
    "www"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['build','admin/assets','admin/index_m.html','www','coverage']) fs.rmSync(p,{recursive:true,force:true});\"",
    "build:adapter": "tsc -p tsconfig.adapter.json",
    "build:editor": "vite build --config vite.editor.config.ts",
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "build": "npm run build:adapter && npm run build:editor && npm run build:viewer",
    "prepare": "npm run build",
    "dev:editor": "vite --config vite.editor.config.ts --host 127.0.0.1",
    "dev:viewer": "vite --config vite.viewer.config.ts --host 127.0.0.1",
    "test": "vitest run",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "lint": "eslint . && tsc -p tsconfig.adapter.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "adapter:check": "npx @iobroker/repochecker dude2k/ioBroker.dashboard-ng"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
